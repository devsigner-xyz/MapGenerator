{
  "name": "mapgenerator",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "dev": "VITE_DOCS_URL=http://127.0.0.1:5174/docs/ vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:lan": "VITE_DOCS_URL=http://127.0.0.1:5174/docs/ vite --host 0.0.0.0 --port 5173 --strictPort",
    "bff:dev": "tsx watch server/src/main.ts",
    "bff:start": "tsx server/src/main.ts",
    "build": "pnpm build:app && pnpm docs:build",
    "build:app": "vite build",
    "docs:dev": "VITE_APP_URL=http://127.0.0.1:5173/app/ vitepress dev docs --host 127.0.0.1 --port 5174 --strictPort",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --port 4174",
    "preview": "vite preview",
    "lint": "pnpm lint:full",
    "lint:frontend": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:server": "eslint \"server/src/**/*.ts\"",
    "lint:tests": "eslint \"tests/**/*.ts\" \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
    "lint:full": "eslint \"src/**/*.{ts,tsx}\" \"server/src/**/*.ts\" \"tests/**/*.ts\" \"*.config.{ts,mts,mjs}\"",
    "typecheck": "pnpm typecheck:all",
    "typecheck:frontend": "tsc -p tsconfig.frontend.json --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "typecheck:all": "pnpm typecheck:frontend && pnpm typecheck:server",
    "typecheck:strict-report": "tsc -p tsconfig.strict.json --noEmit --strict --pretty false",
    "quality:strict-report": "node scripts/quality/strict-report.mjs",
    "quality:budget": "node scripts/quality/check-budget.mjs",
    "test:unit": "pnpm test:unit:frontend && pnpm test:unit:backend",
    "test:unit:frontend": "vitest run --config vitest.config.mts --project frontend",
    "test:unit:backend": "vitest run --config vitest.config.mts --project backend",
    "test:unit:watch": "vitest",
    "test:smoke": "pnpm build && playwright test",
    "test": "pnpm test:unit"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProbableTrain/MapGenerator.git"
  },
  "author": "",
  "license": "LGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/ProbableTrain/MapGenerator/issues"
  },
  "homepage": "https://github.com/ProbableTrain/MapGenerator#readme",
