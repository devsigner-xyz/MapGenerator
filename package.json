    "@nostr-dev-kit/ndk": "^3.0.3",
    "@scure/base": "^2.2.0",
    "@svgdotjs/svg.js": "^3.2.5",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/d3-quadtree": "^3.0.6",
    "@types/dat.gui": "0.7.13",
    "@types/file-saver": "^2.0.7",
    "@types/jsts": "^0.17.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-quadtree": "^3.0.1",
    "dat.gui": "^0.7.9",
    "fastify": "^5.8.5",
    "file-saver": "^2.0.5",
    "interactjs": "^1.10.27",
    "isect": "^3.0.2",
    "jsts": "^2.12.1",
