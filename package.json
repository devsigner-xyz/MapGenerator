    "loglevel": "^1.9.2",
    "lucide-react": "^1.9.0",
    "next-themes": "^0.4.6",
    "nostr-tools": "^2.23.3",
    "polyk": "^0.24.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "recharts": "^3.8.1",
    "roughjs": "^4.6.6",
    "shadcn": "^4.4.0",
    "simplex-noise": "^4.0.3",
    "simplify-js": "^1.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "yet-another-react-lightbox": "^3.31.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5"
  }
