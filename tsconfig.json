{
    "compilerOptions": {
        "noImplicitAny": true,
        "target": "es2018",
        "module": "esnext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": false,
        "ignoreDeprecations": "6.0",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        },
        "lib": ["es2018", "DOM", "DOM.Iterable", "ScriptHost"],
        "types": ["vite/client", "vitest/globals"],
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "src/**/*.d.ts"
    ]
}
